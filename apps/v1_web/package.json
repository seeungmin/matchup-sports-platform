{
  "name": "v1_web",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "sh -c 'mkdir -p .next && find .next -mindepth 1 -maxdepth 1 -exec rm -rf {} + && next dev --hostname 0.0.0.0 --port 3013'",
    "dev:e2e": "next dev --hostname 0.0.0.0 --port 3013",
    "build": "next build",
    "start": "next start",
    "lint": "echo '[v1_web] lint delegated to tsc --noEmit'",
    "clean": "rm -rf .next out",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.17",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "jsdom": "26.1.0",
    "msw": "^2.12.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "3.2.4"
  }
}
