generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum SportType {
  soccer
  futsal
  basketball
  badminton
  ice_hockey
  figure_skating
  short_track
  swimming
  tennis
  baseball
  volleyball
}

enum VenueType {
  futsal_court
  basketball_court
  badminton_court
  ice_rink
  gymnasium
  soccer_field
  swimming_pool
  tennis_court
}

enum MatchStatus {
  recruiting
  confirmed
  full
  in_progress
  completed
  cancelled
}

enum ParticipantStatus {
  pending
  confirmed
  cancelled
}

enum PaymentStatus {
  pending
  completed
  refunded
  partial_refunded
  failed
}

enum PaymentMethod {
  card
  toss_pay
  naver_pay
  kakao_pay
  transfer
}

enum OAuthProvider {
  kakao
  naver
  apple
  email
}

enum UserRole {
  user
  admin
}

enum AdminUserStatus {
  active
  suspended
}

enum AdminUserAuditAction {
  warn
  suspend
  reactivate
}

enum Gender {
  male
  female
}

enum MatchGender {
  any
  male
  female
}

enum NotificationType {
  match_created
  player_joined
  player_left
  team_announced
  match_updated
  match_confirmed
  match_reminder
  match_cancelled
  match_completed
  review_pending
  level_changed
  payment_confirmed
  payment_refunded
  marketplace_order
  marketplace_message
  team_invitation
  elo_changed
  badge_earned
  no_show_penalty
  // Team membership application lifecycle
  team_application_received
  team_application_accepted
  team_application_rejected
  // Team match application lifecycle
  team_match_applied
  team_match_approved
  team_match_rejected
  // Mercenary post application lifecycle
  mercenary_applied
  mercenary_accepted
  mercenary_rejected
  mercenary_closed
  mercenary_cancelled
  // Review and lesson events
  review_received
  lesson_ticket_purchased
  // Chat events (future-proof; delivery not implemented in Task 69)
  chat_message
  // Marketplace payment lifecycle (Task 70)
  marketplace_order_shipped
  marketplace_order_delivered
  marketplace_order_completed
  marketplace_order_disputed
  marketplace_order_refunded
  marketplace_dispute_message
  marketplace_dispute_resolved
  marketplace_payout_paid
}

enum ChatRoomType {
  team_match
  direct
  team
}

enum ChatMessageType {
  text
  system
}

enum ListingStatus {
  active
  sold
  reserved
  expired
  deleted
}

enum TeamRole {
  owner
  manager
  member
}

enum TeamMembershipStatus {
  active
  pending
  left
  removed
}

enum MercenaryPostStatus {
  open
  closed
  filled
  cancelled
}

enum MercenaryApplicationStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum ListingType {
  sell
  rent
  group_buy
}

enum ItemCondition {
  new
  like_new
  good
  fair
  poor
}

enum OrderStatus {
  pending
  paid
  escrow_held
  shipped
  delivered
  completed
  disputed
  refunded
  cancelled
  auto_released // distinguishes cron-triggered release from buyer-confirmed completion for admin audit
}

enum TournamentStatus {
  draft
  recruiting
  full
  ongoing
  completed
  cancelled
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                    String          @id @default(uuid())
  email                 String?         @unique
  passwordHash          String?         @map("password_hash")
  nickname              String          @unique
  role                  UserRole        @default(user)
  adminStatus           AdminUserStatus @default(active) @map("admin_status")
  adminSuspensionReason String?         @map("admin_suspension_reason")
  profileImageUrl       String?         @map("profile_image_url")
  phone                 String?
  gender                Gender?
  birthYear             Int?            @map("birth_year")
  bio                   String?
  sportTypes            SportType[]     @map("sport_types")
  locationLat           Float?          @map("location_lat")
  locationLng           Float?          @map("location_lng")
  locationCity          String?         @map("location_city")
  locationDistrict      String?         @map("location_district")
  mannerScore           Float           @default(3.0) @map("manner_score")
  totalMatches          Int             @default(0) @map("total_matches")

  // OAuth
  oauthProvider OAuthProvider @map("oauth_provider")
  oauthId       String        @map("oauth_id")

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  sportProfiles          UserSportProfile[]
  hostedMatches          Match[]                 @relation("HostedMatches")
  matchParticipations    MatchParticipant[]
  reviews                Review[]                @relation("ReviewAuthor")
  receivedReviews        Review[]                @relation("ReviewTarget")
  payments               Payment[]
  notifications          Notification[]
  venueReviews           VenueReview[]
  listings               MarketplaceListing[]    @relation("ListingSeller")
  orders                 MarketplaceOrder[]      @relation("OrderBuyer")
  soldOrders             MarketplaceOrder[]      @relation("OrderSeller")
  hostedLessons          Lesson[]                @relation("LessonHost")
  ownedVenues            Venue[]                 @relation("VenueOwner")
  lessonTickets          LessonTicket[]          @relation("UserLessonTickets")
  lessonAttendances      LessonAttendance[]      @relation("UserLessonAttendances")
  ownedTeams             SportTeam[]             @relation("TeamOwner")
  organizedTournaments   Tournament[]            @relation("TournamentOrganizer")
  teamMemberships        TeamMembership[]        @relation("TeamMemberships")
  mercenaryApplications  MercenaryApplication[]  @relation("UserMercenaryApplications")
  authoredMercenaryPosts MercenaryPost[]         @relation("MercenaryAuthor")
  chatParticipations     ChatRoomParticipant[]
  sentMessages           ChatMessage[]           @relation("MessageSender")
  pushSubscriptions      PushSubscription[]
  uploads                Upload[]
  sentInvitations        TeamInvitation[]        @relation("InvitationsSent")
  receivedInvitations    TeamInvitation[]        @relation("InvitationsReceived")
  notificationPreference NotificationPreference?
  userBadges             UserBadge[]
  sentReports            Report[]                @relation("ReportsSent")
  blocksFrom             UserBlock[]             @relation("BlocksFrom")
  blocksTo               UserBlock[]             @relation("BlocksTo")
  receivedAdminAuditLogs AdminUserAuditLog[]     @relation("AdminAuditTarget")
  actedAdminAuditLogs    AdminUserAuditLog[]     @relation("AdminAuditActor")
  payouts                Payout[]                @relation("UserPayouts")
  buyerDisputes          Dispute[]               @relation("BuyerDisputes")
  sellerDisputes         Dispute[]               @relation("SellerDisputes")
  disputeMessages        DisputeMessage[]        @relation("DisputeMessages")
  webPushFailureLogs     WebPushFailureLog[]

  @@unique([oauthProvider, oauthId])
  @@index([locationCity, locationDistrict])
  @@index([deletedAt])
  @@map("users")
}

model AdminUserAuditLog {
  id         String               @id @default(cuid())
  userId     String               @map("user_id")
  actorId    String?              @map("actor_id")
  actorLabel String               @map("actor_label")
  action     AdminUserAuditAction
  note       String?
  createdAt  DateTime             @default(now()) @map("created_at")

  user  User  @relation("AdminAuditTarget", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([actorId])
  @@map("admin_user_audit_logs")
}

model UserSportProfile {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  sportType          SportType @map("sport_type")
  level              Int       @default(1)
  eloRating          Int       @default(1000) @map("elo_rating")
  preferredPositions String[]  @map("preferred_positions")
  matchCount         Int       @default(0) @map("match_count")
  winCount           Int       @default(0) @map("win_count")
  mvpCount           Int       @default(0) @map("mvp_count")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sportType])
  @@map("user_sport_profiles")
}

model Venue {
  id             String      @id @default(uuid())
  ownerId        String?     @map("owner_id")
  name           String
  type           VenueType
  sportTypes     SportType[] @map("sport_types")
  address        String
  addressDetail  String?     @map("address_detail")
  lat            Float
  lng            Float
  city           String
  district       String
  phone          String?
  description    String?
  imageUrls      String[]    @map("image_urls")
  facilities     String[]
  operatingHours Json        @map("operating_hours")
  pricePerHour   Int?        @map("price_per_hour")
  rating         Float       @default(0)
  reviewCount    Int         @default(0) @map("review_count")

  // Ice rink specific
  iceQualityAvg Float?  @map("ice_quality_avg")
  rinkSubType   String? @map("rink_sub_type") // full_rink, half_rink

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner        User?                @relation("VenueOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  matches      Match[]
  listings     MarketplaceListing[] @relation("VenueListings")
  tournaments  Tournament[]         @relation("VenueTournaments")
  venueReviews VenueReview[]

  @@index([ownerId])
  @@index([city, district])
  @@index([type])
  @@map("venues")
}

model VenueReview {
  id             String   @id @default(uuid())
  venueId        String   @map("venue_id")
  userId         String   @map("user_id")
  rating         Float
  facilityRating Float    @map("facility_rating")
  accessRating   Float    @map("access_rating")
  costRating     Float    @map("cost_rating")
  iceQuality     Float?   @map("ice_quality")
  comment        String?
  imageUrls      String[] @map("image_urls")
  createdAt      DateTime @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
  @@index([venueId])
  @@map("venue_reviews")
}

model Match {
  id             String      @id @default(uuid())
  hostId         String      @map("host_id")
  sportType      SportType   @map("sport_type")
  title          String
  description    String?
  imageUrl       String?     @map("image_url")
  venueId        String      @map("venue_id")
  matchDate      DateTime    @map("match_date") @db.Date
  startTime      String      @map("start_time") // HH:mm
  endTime        String      @map("end_time") // HH:mm
  maxPlayers     Int         @map("max_players")
  currentPlayers Int         @default(0) @map("current_players")
  fee            Int         @default(0)
  levelMin       Int         @default(1) @map("level_min")
  levelMax       Int         @default(5) @map("level_max")
  gender         MatchGender @default(any)
  status         MatchStatus @default(recruiting)
  teamConfig     Json?       @map("team_config")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  host         User               @relation("HostedMatches", fields: [hostId], references: [id])
  venue        Venue              @relation(fields: [venueId], references: [id])
  participants MatchParticipant[]
  teams        Team[]
  reviews      Review[]

  @@index([sportType, status])
  @@index([status, matchDate])
  @@index([matchDate])
  @@index([venueId])
  @@map("matches")
}

model MatchParticipant {
  id              String            @id @default(uuid())
  matchId         String            @map("match_id")
  userId          String            @map("user_id")
  teamId          String?           @map("team_id")
  status          ParticipantStatus @default(pending)
  paymentStatus   PaymentStatus     @default(pending) @map("payment_status")
  joinedAt        DateTime          @default(now()) @map("joined_at")
  arrivedAt       DateTime?         @map("arrived_at")
  arrivalPhotoUrl String?           @map("arrival_photo_url")
  arrivalLat      Float?            @map("arrival_lat")
  arrivalLng      Float?            @map("arrival_lng")

  match   Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  team    Team?    @relation(fields: [teamId], references: [id])
  payment Payment?

  @@unique([matchId, userId])
  @@index([userId])
  @@index([userId, status])
  @@map("match_participants")
}

model Team {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  name      String
  color     String
  createdAt DateTime @default(now()) @map("created_at")

  match        Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  participants MatchParticipant[]

  @@map("teams")
}

model Review {
  id           String   @id @default(uuid())
  matchId      String   @map("match_id")
  authorId     String   @map("author_id")
  targetId     String   @map("target_id")
  skillRating  Float    @map("skill_rating")
  mannerRating Float    @map("manner_rating")
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  author User  @relation("ReviewAuthor", fields: [authorId], references: [id])
  target User  @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([matchId, authorId, targetId])
  @@index([targetId])
  @@index([authorId])
  @@index([matchId])
  @@map("reviews")
}

model Payment {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  participantId String         @unique @map("participant_id")
  amount        Int
  method        PaymentMethod?
  status        PaymentStatus  @default(pending)
  pgProvider    String?        @map("pg_provider") // toss
  pgTid         String?        @map("pg_tid")
  paymentKey    String?        @unique @map("payment_key")
  orderId       String         @unique @map("order_id")
  receiptUrl    String?        @map("receipt_url")
  cardNumber    String?        @map("card_number") // masked
  refundAmount  Int?           @map("refund_amount")
  refundReason  String?        @map("refund_reason")
  paidAt        DateTime?      @map("paid_at")
  refundedAt    DateTime?      @map("refunded_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id])
  participant MatchParticipant @relation(fields: [participantId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("payments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Marketplace ─────────────────────────────────────────

model MarketplaceListing {
  id               String        @id @default(uuid())
  sellerId         String        @map("seller_id")
  teamId           String?       @map("team_id")
  venueId          String?       @map("venue_id")
  title            String
  description      String
  sportType        SportType     @map("sport_type")
  category         String
  condition        ItemCondition
  price            Int
  listingType      ListingType   @default(sell) @map("listing_type")
  status           ListingStatus @default(active)
  imageUrls        String[]      @map("image_urls")
  locationCity     String?       @map("location_city")
  locationDistrict String?       @map("location_district")
  viewCount        Int           @default(0) @map("view_count")
  likeCount        Int           @default(0) @map("like_count")

  // Rental fields
  rentalPricePerDay Int? @map("rental_price_per_day")
  rentalDeposit     Int? @map("rental_deposit")

  // Group buy fields
  groupBuyTarget   Int?      @map("group_buy_target")
  groupBuyDeadline DateTime? @map("group_buy_deadline")
  groupBuyCurrent  Int?      @default(0) @map("group_buy_current")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  expiresAt DateTime? @map("expires_at")

  seller User               @relation("ListingSeller", fields: [sellerId], references: [id])
  team   SportTeam?         @relation("TeamListings", fields: [teamId], references: [id], onDelete: SetNull)
  venue  Venue?             @relation("VenueListings", fields: [venueId], references: [id], onDelete: SetNull)
  orders MarketplaceOrder[]

  @@index([sportType, category])
  @@index([status])
  @@index([status, sportType])
  @@index([locationCity])
  @@index([teamId, status, createdAt])
  @@index([venueId, status, createdAt])
  @@map("marketplace_listings")
}

model MarketplaceOrder {
  id         String      @id @default(uuid())
  listingId  String      @map("listing_id")
  buyerId    String      @map("buyer_id")
  sellerId   String      @map("seller_id")
  amount     Int
  commission Int         @default(0)
  status     OrderStatus @default(pending)
  paymentKey String?     @unique @map("payment_key")
  orderId    String      @unique @map("order_id")

  // Rental
  rentalStartDate DateTime? @map("rental_start_date")
  rentalEndDate   DateTime? @map("rental_end_date")

  paidAt             DateTime? @map("paid_at")
  shippedAt          DateTime? @map("shipped_at")
  deliveredAt        DateTime? @map("delivered_at")
  completedAt        DateTime? @map("completed_at")
  autoReleaseAt      DateTime? @map("auto_release_at")         // when escrow auto-releases (T+7 after delivered)
  releasedAt         DateTime? @map("released_at")             // actual release timestamp
  confirmedReceiptAt DateTime? @map("confirmed_receipt_at")    // buyer explicitly confirmed receipt
  forceReleasedByAdminId String? @map("force_released_by_admin_id") // admin who force-released the escrow
  forceReleasedAt    DateTime? @map("force_released_at")       // timestamp of admin force-release
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  listing     MarketplaceListing @relation(fields: [listingId], references: [id])
  buyer       User               @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller      User               @relation("OrderSeller", fields: [sellerId], references: [id])
  disputes    Dispute[]
  settlements SettlementRecord[] @relation("OrderSettlements")

  @@index([buyerId])
  @@index([sellerId])
  @@index([status, autoReleaseAt])
  @@map("marketplace_orders")
}

// ─── Lessons / 강좌 ─────────────────────────────────────

enum LessonType {
  group_lesson // 그룹 레슨 (코치 진행)
  practice_match // 연습 경기
  free_practice // 자유 연습 (코트/링크 대여)
  clinic // 클리닉/워크숍
}

enum LessonStatus {
  open
  closed
  cancelled
  completed
}

enum TicketType {
  single // 1회권
  multi // 다회권 (N회)
  unlimited // 기간권 (무제한)
}

enum TicketStatus {
  active // 사용중
  expired // 기간 만료
  exhausted // 횟수 소진
  refunded // 환불됨
  cancelled // 취소됨
}

enum AttendanceStatus {
  scheduled // 예약됨
  attended // 출석
  absent // 결석
  late // 지각
  cancelled // 취소됨
}

model Lesson {
  id                  String       @id @default(uuid())
  hostId              String       @map("host_id")
  teamId              String?      @map("team_id")
  sportType           SportType    @map("sport_type")
  type                LessonType
  title               String
  description         String?
  venueId             String?      @map("venue_id")
  venueName           String?      @map("venue_name") // 직접 입력
  lessonDate          DateTime     @map("lesson_date") @db.Date
  startTime           String       @map("start_time")
  endTime             String       @map("end_time")
  maxParticipants     Int          @map("max_participants")
  currentParticipants Int          @default(0) @map("current_participants")
  fee                 Int          @default(0)
  levelMin            Int          @default(1) @map("level_min")
  levelMax            Int          @default(5) @map("level_max")
  status              LessonStatus @default(open)
  imageUrls           String[]     @map("image_urls")

  // Coach info
  coachName     String? @map("coach_name")
  coachBio      String? @map("coach_bio")
  coachImageUrl String? @map("coach_image_url")

  // Recurring schedule
  isRecurring    Boolean   @default(false) @map("is_recurring")
  recurringDays  Int[]     @map("recurring_days") // e.g. [1,3,5] for Mon/Wed/Fri (0=Sun)
  recurringUntil DateTime? @map("recurring_until") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  host        User               @relation("LessonHost", fields: [hostId], references: [id])
  team        SportTeam?         @relation("TeamLessons", fields: [teamId], references: [id], onDelete: SetNull)
  ticketPlans LessonTicketPlan[]
  tickets     LessonTicket[]
  schedules   LessonSchedule[]

  @@index([sportType, status])
  @@index([lessonDate])
  @@index([teamId, status, lessonDate])
  @@index([venueId, status, lessonDate])
  @@map("lessons")
}

model LessonTicketPlan {
  id            String     @id @default(uuid())
  lessonId      String     @map("lesson_id")
  name          String // e.g. "10회권", "1개월 무제한"
  type          TicketType
  price         Int
  originalPrice Int?       @map("original_price") // for displaying discounts
  totalSessions Int?       @map("total_sessions") // required for multi type
  validDays     Int?       @map("valid_days") // required for unlimited type
  description   String?
  isActive      Boolean    @default(true) @map("is_active")
  sortOrder     Int        @default(0) @map("sort_order")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  lesson  Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tickets LessonTicket[]

  @@index([lessonId, isActive])
  @@map("lesson_ticket_plans")
}

model LessonTicket {
  id            String       @id @default(uuid())
  planId        String       @map("plan_id")
  userId        String       @map("user_id")
  lessonId      String       @map("lesson_id")
  status        TicketStatus @default(active)
  totalSessions Int?         @map("total_sessions") // snapshot from plan at purchase time
  usedSessions  Int          @default(0) @map("used_sessions")
  startDate     DateTime?    @map("start_date") @db.Date
  expiresAt     DateTime?    @map("expires_at") @db.Date
  paymentId     String?      @unique @map("payment_id")
  paidAmount    Int          @map("paid_amount")
  purchasedAt   DateTime     @default(now()) @map("purchased_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  plan        LessonTicketPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  user        User               @relation("UserLessonTickets", fields: [userId], references: [id])
  lesson      Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attendances LessonAttendance[]

  @@index([userId, status])
  @@index([lessonId])
  @@index([expiresAt])
  @@map("lesson_tickets")
}

model LessonSchedule {
  id              String   @id @default(uuid())
  lessonId        String   @map("lesson_id")
  sessionDate     DateTime @map("session_date") @db.Date
  startTime       String   @map("start_time") // HH:mm
  endTime         String   @map("end_time") // HH:mm
  maxParticipants Int?     @map("max_participants")
  note            String?
  isCancelled     Boolean  @default(false) @map("is_cancelled")
  cancelReason    String?  @map("cancel_reason")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lesson      Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attendances LessonAttendance[]

  @@index([lessonId, sessionDate])
  @@index([sessionDate])
  @@map("lesson_schedules")
}

model LessonAttendance {
  id          String           @id @default(uuid())
  scheduleId  String           @map("schedule_id")
  ticketId    String           @map("ticket_id")
  userId      String           @map("user_id")
  status      AttendanceStatus @default(scheduled)
  checkedInAt DateTime?        @map("checked_in_at")
  checkedInBy String?          @map("checked_in_by") // userId of coach or staff who checked in
  createdAt   DateTime         @default(now()) @map("created_at")

  schedule LessonSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  ticket   LessonTicket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user     User           @relation("UserLessonAttendances", fields: [userId], references: [id])

  @@unique([scheduleId, userId])
  @@index([ticketId])
  @@index([userId])
  @@map("lesson_attendances")
}

// ─── 팀/클럽 홍보 ───────────────────────────────────────

model SportTeam {
  id            String      @id @default(uuid())
  ownerId       String      @map("owner_id")
  name          String
  sportTypes    SportType[] @map("sport_types")
  description   String?
  logoUrl       String?     @map("logo_url")
  coverImageUrl String?     @map("cover_image_url")
  photos        String[]    @default([])
  city          String?
  district      String?
  memberCount   Int         @default(1) @map("member_count")
  level         Int         @default(3) // 팀 평균 레벨
  isRecruiting  Boolean     @default(true) @map("is_recruiting")
  contactInfo   String?     @map("contact_info") // 연락처/오픈카톡

  // SNS & 홍보
  instagramUrl  String? @map("instagram_url")
  youtubeUrl    String? @map("youtube_url")
  shortsUrl     String? @map("shorts_url") // 홍보 영상 (shorts/reels)
  kakaoOpenChat String? @map("kakao_open_chat")
  websiteUrl    String? @map("website_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  owner User @relation("TeamOwner", fields: [ownerId], references: [id])

  teamMatches      TeamMatch[]            @relation("TeamMatchHost")
  teamApplications TeamMatchApplication[] @relation("TeamAppApplicant")
  lessons          Lesson[]               @relation("TeamLessons")
  listings         MarketplaceListing[]   @relation("TeamListings")
  tournaments      Tournament[]           @relation("TeamTournaments")
  memberships      TeamMembership[]
  mercenaryPosts   MercenaryPost[]
  invitations      TeamInvitation[]

  @@index([city, isRecruiting])
  @@index([deletedAt])
  @@map("sport_teams")
}

model Tournament {
  id                  String           @id @default(uuid())
  organizerId         String           @map("organizer_id")
  teamId              String?          @map("team_id")
  venueId             String?          @map("venue_id")
  sportType           SportType        @map("sport_type")
  title               String
  description         String?
  startDate           DateTime         @map("start_date") @db.Date
  endDate             DateTime         @map("end_date") @db.Date
  entryFee            Int              @default(0) @map("entry_fee")
  maxParticipants     Int?             @map("max_participants")
  currentParticipants Int              @default(0) @map("current_participants")
  status              TournamentStatus @default(recruiting)
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  organizer User       @relation("TournamentOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  team      SportTeam? @relation("TeamTournaments", fields: [teamId], references: [id], onDelete: SetNull)
  venue     Venue?     @relation("VenueTournaments", fields: [venueId], references: [id], onDelete: SetNull)

  @@index([sportType, status])
  @@index([startDate, status])
  @@index([teamId, status, startDate])
  @@index([venueId, status, startDate])
  @@map("tournaments")
}

// ─── Team Membership ────────────────────────────────────

model TeamMembership {
  id            String               @id @default(uuid())
  teamId        String               @map("team_id")
  userId        String               @map("user_id")
  role          TeamRole             @default(member)
  status        TeamMembershipStatus @default(active)
  joinedAt      DateTime             @default(now()) @map("joined_at")
  leftAt        DateTime?            @map("left_at")
  invitedBy     String?              @map("invited_by")
  roleChangedAt DateTime?            @map("role_changed_at")

  team SportTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation("TeamMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId, status])
  @@index([teamId, role])
  @@map("team_memberships")
}

// ─── Mercenary Posts ─────────────────────────────────────

model MercenaryPost {
  id        String              @id @default(uuid())
  teamId    String              @map("team_id")
  authorId  String              @map("author_id")
  sportType SportType           @map("sport_type")
  matchDate DateTime            @map("match_date")
  venue     String
  position  String
  count     Int                 @default(1)
  level     Int                 @default(3)
  fee       Int                 @default(0)
  notes     String?
  status    MercenaryPostStatus @default(open)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  team         SportTeam              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author       User                   @relation("MercenaryAuthor", fields: [authorId], references: [id])
  applications MercenaryApplication[]

  @@index([sportType, status])
  @@index([teamId])
  @@index([matchDate])
  @@map("mercenary_posts")
}

model MercenaryApplication {
  id        String                     @id @default(uuid())
  postId    String                     @map("post_id")
  userId    String                     @map("user_id")
  message   String?
  status    MercenaryApplicationStatus @default(pending)
  appliedAt DateTime                   @default(now()) @map("applied_at")
  decidedAt DateTime?                  @map("decided_at")
  decidedBy String?                    @map("decided_by")

  post MercenaryPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation("UserMercenaryApplications", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([userId, status])
  @@map("mercenary_applications")
}

// ─── 팀 매칭 시스템 ─────────────────────────────────────

enum TeamMatchStatus {
  recruiting // 모집중
  applied // 신청됨
  approved // 승인됨
  rejected // 거절됨
  scheduled // 경기예정
  checking_in // 도착확인중
  in_progress // 경기중
  completed // 경기완료
  cancelled // 취소
  late // 지각
  no_show // 노쇼
  disputed // 분쟁검토중
}

enum TeamMatchApplicationStatus {
  pending
  approved
  rejected
  withdrawn
}

enum MatchStyle {
  friendly // 친선전
  competitive // 실전형
  manner_focused // 매너 위주
}

enum ParticipationType {
  team // 팀 참여
  guest // 게스트 참여
  regular // 정기 참여
  mercenary // 용병
}

model TeamMatch {
  id         String    @id @default(uuid())
  hostTeamId String    @map("host_team_id")
  sportType  SportType @map("sport_type")

  // 경기 정보
  title        String
  description  String?
  matchDate    DateTime @map("match_date") @db.Date
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  totalMinutes Int      @default(120) @map("total_minutes")
  quarterCount Int      @default(4) @map("quarter_count") // 2,4,6,8,10

  // 구장 정보
  venueName    String @map("venue_name")
  venueAddress String @map("venue_address")
  venueInfo    Json?  @map("venue_info") // 실내/외, 주차, 샤워실 등

  // 비용
  totalFee           Int     @default(0) @map("total_fee")
  opponentFee        Int     @default(0) @map("opponent_fee")
  paymentDeadline    String? @map("payment_deadline")
  cancellationPolicy String? @map("cancellation_policy")

  // 매칭 조건
  gender         MatchGender @default(any)
  requiredLevel  Int?        @map("required_level")
  hasProPlayers  Boolean    @default(false) @map("has_pro_players")
  allowMercenary Boolean    @default(true) @map("allow_mercenary")
  matchStyle     MatchStyle @default(friendly) @map("match_style")
  hasReferee     Boolean    @default(false) @map("has_referee")
  notes          String?

  // task 17: match meta fields
  skillGrade       String? @map("skill_grade")
  gameFormat       String? @map("game_format")
  matchType        String? @map("match_type")
  proPlayerCount   Int     @default(0) @map("pro_player_count")
  uniformColor     String? @map("uniform_color")
  isFreeInvitation Boolean @default(false) @map("is_free_invitation")

  // 상태
  status      TeamMatchStatus @default(recruiting)
  guestTeamId String?         @map("guest_team_id") // 승인된 상대 팀

  // 심판 배정 (JSON: 쿼터별 담당팀)
  refereeSchedule Json? @map("referee_schedule")

  // 경기 결과
  scoreHome  Json?   @map("score_home") // 쿼터별 점수
  scoreAway  Json?   @map("score_away")
  resultHome String? @map("result_home") // win/draw/lose
  resultAway String? @map("result_away")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  hostTeam      SportTeam              @relation("TeamMatchHost", fields: [hostTeamId], references: [id])
  applications  TeamMatchApplication[]
  arrivalChecks ArrivalCheck[]
  evaluations   MatchEvaluation[]
  chatRoom      ChatRoom?
  disputes      Dispute[]              @relation("TeamMatchDisputes")

  @@index([sportType, status])
  @@index([matchDate])
  @@index([hostTeamId, status, matchDate])
  @@map("team_matches")
}

model TeamMatchApplication {
  id              String                     @id @default(uuid())
  teamMatchId     String                     @map("team_match_id")
  applicantTeamId String                     @map("applicant_team_id")
  status          TeamMatchApplicationStatus @default(pending)

  // 상호 확인 체크 (2단계)
  confirmedInfo  Boolean  @default(false) @map("confirmed_info") // 상대 팀 정보 확인
  confirmedLevel Boolean  @default(false) @map("confirmed_level") // 수준 차이 인지
  proPlayerCheck Boolean? @map("pro_player_check") // 선수 출신 유무 확인
  mercenaryCheck Boolean? @map("mercenary_check") // 용병 여부 확인

  message           String? // 신청 메시지
  participationType ParticipationType @default(team) @map("participation_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teamMatch     TeamMatch @relation(fields: [teamMatchId], references: [id], onDelete: Cascade)
  applicantTeam SportTeam @relation("TeamAppApplicant", fields: [applicantTeamId], references: [id])

  @@unique([teamMatchId, applicantTeamId])
  @@index([applicantTeamId])
  @@map("team_match_applications")
}

model ArrivalCheck {
  id          String  @id @default(uuid())
  teamMatchId String  @map("team_match_id")
  teamId      String  @map("team_id")
  isHome      Boolean @map("is_home") // 홈팀 여부

  // 도착 인증
  arrivedAt DateTime? @map("arrived_at")
  lat       Float? // GPS 위도
  lng       Float? // GPS 경도
  photoUrl  String?   @map("photo_url") // 현장 사진

  // 상대팀 확인
  opponentStatus String? @map("opponent_status") // normal, late, no_show
  opponentNote   String? @map("opponent_note")

  // 경기 완료 확인
  gameCompleted Boolean? @map("game_completed")

  createdAt DateTime @default(now()) @map("created_at")

  teamMatch TeamMatch @relation(fields: [teamMatchId], references: [id], onDelete: Cascade)

  @@unique([teamMatchId, teamId])
  @@map("arrival_checks")
}

model MatchEvaluation {
  id              String @id @default(uuid())
  teamMatchId     String @map("team_match_id")
  evaluatorTeamId String @map("evaluator_team_id")
  evaluatedTeamId String @map("evaluated_team_id")

  // 6항목 평가 (1-5)
  levelAccuracy  Int @map("level_accuracy") // 수준 사전설명 일치
  infoAccuracy   Int @map("info_accuracy") // 선수출신/용병 고지 일치
  mannerRating   Int @map("manner_rating") // 매너
  punctuality    Int @map("punctuality") // 시간 약속
  paymentClarity Int @map("payment_clarity") // 비용 정산
  cooperation    Int @map("cooperation") // 경기 운영 협조

  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  teamMatch TeamMatch @relation(fields: [teamMatchId], references: [id], onDelete: Cascade)

  @@unique([teamMatchId, evaluatorTeamId])
  @@map("match_evaluations")
}

model TeamTrustScore {
  id     String @id @default(uuid())
  teamId String @unique @map("team_id")

  // 실력 관련
  selfLevel Int    @default(3) @map("self_level") // 자기기입
  peerLevel Float? @map("peer_level") // 상대평가 누적 평균

  // 신뢰 관련
  infoAccuracy Float @default(100) @map("info_accuracy") // 정보 일치도 %
  mannerScore  Float @default(3.0) @map("manner_score")
  lateRate     Float @default(0) @map("late_rate") // 지각률 %
  noShowRate   Float @default(0) @map("no_show_rate") // 노쇼율 %
  cancelRate   Float @default(0) @map("cancel_rate") // 취소율 %

  // 통계
  totalMatches Int @default(0) @map("total_matches")
  totalWins    Int @default(0) @map("total_wins")
  totalDraws   Int @default(0) @map("total_draws")
  totalLosses  Int @default(0) @map("total_losses")
  refereeTimes Int @default(0) @map("referee_times") // 심판 봉사 횟수

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_trust_scores")
}

model Badge {
  id          String   @id @default(uuid())
  teamId      String   @map("team_id")
  type        String // manner_player, punctual, referee_hero, honest_team, newcomer
  name        String
  description String?
  earnedAt    DateTime @default(now()) @map("earned_at")

  @@index([teamId])
  @@map("badges")
}

model SeedSyncState {
  key       String   @id
  checksum  String
  payload   Json?
  appliedAt DateTime @default(now()) @map("applied_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("seed_sync_states")
}

// ─── Chat ────────────────────────────────────────────────

model ChatRoom {
  id            String       @id @default(uuid())
  type          ChatRoomType
  teamMatchId   String?      @unique @map("team_match_id")
  lastMessageAt DateTime?    @map("last_message_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  teamMatch    TeamMatch?            @relation(fields: [teamMatchId], references: [id], onDelete: SetNull)
  participants ChatRoomParticipant[]
  messages     ChatMessage[]

  @@index([lastMessageAt])
  @@map("chat_rooms")
}

model ChatRoomParticipant {
  roomId     String    @map("room_id")
  userId     String    @map("user_id")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
  @@map("chat_room_participants")
}

model ChatMessage {
  id        String          @id @default(uuid())
  roomId    String          @map("room_id")
  senderId  String?         @map("sender_id")
  content   String          @db.VarChar(2000)
  type      ChatMessageType @default(text)
  imageUrl  String?         @map("image_url")
  deletedAt DateTime?       @map("deleted_at")
  createdAt DateTime        @default(now()) @map("created_at")

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User?    @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId, createdAt])
  @@map("chat_messages")
}

// ─── Uploads ─────────────────────────────────────────────

model Upload {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  filename     String
  originalName String   @map("original_name")
  mimetype     String
  size         Int
  path         String // relative path: uploads/YYYY/MM/cuid.webp
  width        Int?
  height       Int?
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("uploads")
}

// ─── Web Push Subscriptions ──────────────────────────────

model PushSubscription {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  endpoint   String    @unique
  p256dh     String
  auth       String
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Team Invitations ───────────────────────────────────

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}

model TeamInvitation {
  id        String           @id @default(cuid())
  teamId    String           @map("team_id")
  inviterId String           @map("inviter_id")
  inviteeId String           @map("invitee_id")
  role      TeamRole         @default(member)
  status    InvitationStatus @default(pending)
  expiresAt DateTime         @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  team    SportTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User      @relation("InvitationsSent", fields: [inviterId], references: [id])
  invitee User      @relation("InvitationsReceived", fields: [inviteeId], references: [id])

  @@unique([teamId, inviteeId])
  @@index([inviteeId, status])
  @@map("team_invitations")
}

// ─── Notification Preferences ───────────────────────────

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  matchEnabled   Boolean  @default(true) @map("match_enabled")
  teamEnabled    Boolean  @default(true) @map("team_enabled")
  chatEnabled    Boolean  @default(true) @map("chat_enabled")
  paymentEnabled Boolean  @default(true) @map("payment_enabled")
  // Granular overrides — opt-out model (all true by default)
  teamApplicationEnabled Boolean @default(true) @map("team_application_enabled")
  matchCompletedEnabled  Boolean @default(true) @map("match_completed_enabled")
  eloChangedEnabled      Boolean @default(true) @map("elo_changed_enabled")
  chatMessageEnabled     Boolean @default(true) @map("chat_message_enabled")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── Settlements (persistent) ───────────────────────────

enum SettlementType {
  match
  marketplace
  lesson
}

enum SettlementStatus {
  pending
  processing
  completed
  failed
  refunded // funds returned to buyer after dispute resolution
  held     // settlement created but payout not yet triggered
}

// ─── Marketplace Dispute & Payout ───────────────────────

enum DisputeStatus {
  filed
  seller_responded
  admin_reviewing
  resolved_refund
  resolved_release
  withdrawn
  dismissed
}

enum DisputeActorRole {
  buyer
  seller
  admin
}

enum DisputeTargetType {
  marketplace_order
  team_match
}

enum PayoutStatus {
  pending
  processing
  paid
  failed
  cancelled
}

model SettlementRecord {
  id          String           @id @default(cuid())
  type        SettlementType
  sourceId    String           @map("source_id") // orderId / paymentId / ticketId
  orderId     String?          @map("order_id")  // FK to marketplace_orders for marketplace type
  amount      Int // gross amount
  commission  Int // platform commission (10%)
  netAmount   Int              @map("net_amount") // amount - commission
  recipientId String?          @map("recipient_id") // seller or instructor
  status      SettlementStatus @default(pending)
  processedAt DateTime?        @map("processed_at")
  releasedAt  DateTime?        @map("released_at") // when escrow was released
  payoutId    String?          @map("payout_id")   // FK to payouts batch
  createdAt   DateTime         @default(now()) @map("created_at")

  order  MarketplaceOrder? @relation("OrderSettlements", fields: [orderId], references: [id], onDelete: SetNull)
  payout Payout?           @relation("PayoutSettlements", fields: [payoutId], references: [id], onDelete: SetNull)

  @@unique([orderId, type])
  @@index([type, status])
  @@index([recipientId])
  @@index([payoutId])
  @@map("settlement_records")
}

// ─── User Badges (persistent) ───────────────────────────

model UserBadge {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String
  name        String
  description String?
  earnedAt    DateTime @default(now()) @map("earned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("user_badges")
}

// ─── Reports & User Blocks ──────────────────────────────

enum ReportTargetType {
  user
  message
  listing
  review
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String           @map("reporter_id")
  targetType  ReportTargetType @map("target_type")
  targetId    String           @map("target_id")
  reason      String
  description String?
  status      ReportStatus     @default(pending)
  createdAt   DateTime         @default(now()) @map("created_at")

  reporter User @relation("ReportsSent", fields: [reporterId], references: [id])

  @@index([status])
  @@index([targetType, targetId])
  @@map("reports")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksFrom", fields: [blockerId], references: [id])
  blocked User @relation("BlocksTo", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

// ─── Payout (admin-triggered seller bank transfers) ─────

model Payout {
  id                  String       @id @default(cuid())
  batchId             String       @map("batch_id")          // shared across all payouts in one admin batch run
  recipientId         String       @map("recipient_id")      // seller user id
  grossAmount         Int          @map("gross_amount")      // sum of settlement gross amounts
  platformFee         Int          @map("platform_fee")      // sum of settlement commissions
  netAmount           Int          @map("net_amount")        // grossAmount - platformFee; transferred to seller
  status              PayoutStatus @default(pending)
  note                String?
  failureReason       String?      @map("failure_reason")
  paidAt              DateTime?    @map("paid_at")
  processedAt         DateTime?    @map("processed_at")
  markedPaidByAdminId String?      @map("marked_paid_by_admin_id")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  recipient    User               @relation("UserPayouts", fields: [recipientId], references: [id])
  settlements  SettlementRecord[] @relation("PayoutSettlements")

  @@index([batchId])
  @@index([recipientId, status])
  @@index([status])
  @@map("payouts")
}

// ─── Dispute (marketplace order & team-match disputes) ──

model Dispute {
  id                String            @id @default(cuid())
  targetType        DisputeTargetType @map("target_type")
  orderId           String?           @unique @map("order_id")         // FK when targetType = marketplace_order
  teamMatchId       String?           @map("team_match_id")            // FK when targetType = team_match
  type              String            @map("type")                     // reason code e.g. "item_not_received", "item_not_as_described"
  status            DisputeStatus     @default(filed)
  buyerId           String            @map("buyer_id")                 // disputing party (or host for team-match)
  sellerId          String            @map("seller_id")                // responding party
  description       String
  evidence          String[]          @default([])                     // URLs to uploaded evidence files
  priorOrderStatus  OrderStatus       @map("prior_order_status")       // order status at time of dispute filing; used to restore on withdraw/dismiss
  resolvedByAdminId String?           @map("resolved_by_admin_id")     // admin who resolved the dispute
  resolvedAt        DateTime?         @map("resolved_at")
  resolution        String?                                            // admin resolution note
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  order     MarketplaceOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  teamMatch TeamMatch?        @relation("TeamMatchDisputes", fields: [teamMatchId], references: [id], onDelete: SetNull)
  buyer     User              @relation("BuyerDisputes", fields: [buyerId], references: [id])
  seller    User              @relation("SellerDisputes", fields: [sellerId], references: [id])
  messages  DisputeMessage[]
  events    DisputeEvent[]

  @@index([status])
  @@index([buyerId])
  @@index([sellerId])
  @@map("disputes")
}

model DisputeMessage {
  id        String           @id @default(cuid())
  disputeId String           @map("dispute_id")
  authorId  String           @map("author_id")
  role      DisputeActorRole
  body      String
  createdAt DateTime         @default(now()) @map("created_at")

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  author  User    @relation("DisputeMessages", fields: [authorId], references: [id])

  @@index([disputeId, createdAt])
  @@map("dispute_messages")
}

model DisputeEvent {
  id          String            @id @default(cuid())
  disputeId   String            @map("dispute_id")
  actorRole   DisputeActorRole? @map("actor_role")
  actorUserId String?           @map("actor_user_id")
  eventType   String            @map("event_type")   // e.g. 'refund', 'release', 'dismiss', 'withdraw', 'force_release'
  payload     Json?                                   // additional context (adminId, note, etc.)
  createdAt   DateTime          @default(now()) @map("created_at")

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId, createdAt])
  @@map("dispute_events")
}

model WebPushFailureLog {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  subscriptionId String?   @map("subscription_id")
  statusCode     Int?      @map("status_code")
  errorCode      String?   @map("error_code")
  endpointSuffix String    @map("endpoint_suffix")
  occurredAt     DateTime  @default(now()) @map("occurred_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  acknowledgedBy String?   @map("acknowledged_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([occurredAt])
  @@index([acknowledgedAt])
  @@index([userId])
  @@map("web_push_failure_logs")
}
